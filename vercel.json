{
  "version": 2,
  "buildCommand": "pnpm --prefix Experience-Hub run vercel-build",
  "outputDirectory": "Experience-Hub/artifacts/experiment-library/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "Experience-Hub/artifacts/api-server/experiments/**, Experience-Hub/artifacts/api-server/outputs/**"
    }
  }
}
