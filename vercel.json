{
  "version": 2,
  "build": "pnpm run vercel-build",
  "outputDirectory": "artifacts/experiment-library/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "artifacts/api-server/experiments/**, artifacts/api-server/outputs/**"
    }
  }
}
